<%-include("../components/head.ejs")%>

  <body>
    <%-include("../components/nav.ejs")%>
      <main>
        <h1><%= title %>: <%= venta.id_venta %></h1>

        <form class="formEntidad" action="/ventas/editar/<%= venta.id_venta %>?_method=PUT"  method="post">

          <div class="row">
            <label>Método de Pago:</label>
            <select id="id_metodo" name="id_metodo">
              <% metodos_pago_list.forEach((m) => { %>
                <option value="<%= m.id_metodo %>"
                  <%= m.id_metodo == venta.id_metodo ? 'selected' : '' %>>
                  <%= m.nombre %>
                </option>
              <% }); %>
            </select>
          </div>

          <br>

          <div>
            <label for="fecha">Fecha y Hora de la Venta</label><br>
            <% 
              const fechaObjeto = new Date(venta.fecha);
            
              fechaObjeto.setMinutes(fechaObjeto.getMinutes() - fechaObjeto.getTimezoneOffset());
              
              const fechaFormateada = fechaObjeto.toISOString().slice(0, 16);
            %>
            <input type="datetime-local" 
                  id="fecha" 
                  name="fecha"
                  value="<%= fechaFormateada %>" 
                  required>
          </div>

          <br>

          <label id="precio_unitario">Total
            <input type="number" step="0.01" name="total" value="<%= venta.total %>" required>
          </label><br>

           <input type="submit"  value="Guardar Cambios">

        </form>
      </main>
  </body>

  <%-include("../components/footer.ejs")%>