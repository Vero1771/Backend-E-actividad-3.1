<%-include("../components/head.ejs")%>

  <body>

    <%-include("../components/nav.ejs")%>
    <main>
      <h1><%= title %></h1>

      <form class="formEntidad" id="formEditarFuncion">

        <div>
          <label for="id_pelicula">Elige una Película</label><br>
          <% if(peliculas_list.length > 0) { %>
            <select name="id_pelicula" id="id_pelicula" required>
              <% peliculas_list.forEach((p) => { %>
                <option value="<%= p.id_pelicula %>" 
                  <%= p.id_pelicula == funcion.id_pelicula ? 'selected' : '' %>>
                  <%= p.titulo %>
                </option>
              <% }); %>
            </select>
          <% } %>
        </div>

        <br>

        <div>
          <label for="id_sala">Elige una Sala</label><br>
          <% if(salas_list.length > 0) { %>
            <select name="id_sala" id="id_sala" required>
              <% salas_list.forEach((s) => { %>
                <option value="<%= s.id_sala %>"
                  <%= s.id_sala == funcion.id_sala ? 'selected' : '' %>>
                  <%= s.nombre %>
                </option>
              <% }); %>
            </select>
          <% } %>
        </div>

        <br>

        <div>
          <label for="fecha_hora">Fecha y Hora de la Función</label><br>
          <% 
            const fechaObjeto = new Date(funcion.fecha_hora);
            
            fechaObjeto.setMinutes(fechaObjeto.getMinutes() - fechaObjeto.getTimezoneOffset());
              
            const fechaFormateada = fechaObjeto.toISOString().slice(0, 16);
          %>
          <input type="datetime-local" 
                id="fecha_hora" 
                name="fecha_hora"
                value="<%= fechaFormateada %>" 
                required>
        </div>
              
        <br>

        <button class="formEntidad__submit" type="button" onclick="actualizarFuncion('<%= funcion.id_funcion %>')">Guardar Cambios</button>

      </form>

       <script>
          async function actualizarFuncion(id) {
            const data = {
              id_pelicula: document.getElementById('id_pelicula').value,
              id_sala: document.getElementById('id_sala').value,
              fecha_hora: document.getElementById('fecha_hora').value
            };

            try {
              const response = await fetch(`/funciones/editar/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
              });

              const result = await response.json();

              if (response.ok) {
                alert("Función actualizada con éxito");
                window.location.href = '/funciones'; // Redirigir a la lista
              } else {
                // Si el servidor responde con 400 mostrar los mensajes de error
                const mensajesError = result.result.join("\n"); 
                alert("Error en la validación:\n" + mensajesError);
              }
            } catch (error) {
              console.error("Error:", error);
              alert("Ocurrió un problema al conectar con el servidor.");
            }
          }
        </script>

    </main>
  </body>

  <%-include("../components/footer.ejs")%>