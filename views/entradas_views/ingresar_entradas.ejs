<%-include("../components/head.ejs")%>

  <body>
    <%-include("../components/nav.ejs")%>
    <main>
      <h1>Ingresar <%= title %></h1>

      <div class="container">   
        
        <div class="row">
          <label>Método de Pago:</label>
            <select id="id_metodo">
              <% metodos_pago_list.forEach(m => { %>
                <option value="<%= m.id_metodo %>">
                  <%= m.nombre %>
                </option>
              <% }) %>
            </select>
        </div>

        <div class="row">
          <label>Seleccionar Función:</label>
            <select id="id_funcion_master">
              <% funciones_list.forEach(f => { %>
                <option value="<%= f.id_funcion %>">
                  <%= f.titulo %> - <%= f.fecha_hora.toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' }) %>
                </option>
              <% }) %>
            </select>
          </div>

        <div id="mapa-asientos">
          <label>Elegir Asientos</label><br>
            <% if(asientos_list.length > 0) { %>
              <% asientos_list.forEach((a) => { %>

                <label>
                  <input type="checkbox" class="asiento-check" value="<%= a.id_asiento %>">
                  <%= a.nombre %>
                </label><br>

              <% }); %>
            <% } else { %>
              <p>No hay Asientos para asignar</p>
            <% } %>
        </div>

        <label for="precio">Precio Cobrado:</label>
        <input type="number" step="0.01" name="precio" id="id_precio_entradas">

          <button type="button" onclick="enviarVenta()">Finalizar Venta</button>
      </div>


      <script>
        async function enviarVenta() {
            const id_metodo = document.getElementById('id_metodo').value;
            const id_funcion = document.getElementById('id_funcion_master').value;
            const precio = document.getElementById('id_precio_entradas').value;

            // Obtener los checkboxs marcados
            const asientosSeleccionados = Array.from(document.querySelectorAll('.asiento-check:checked'))
                .map(cb => ({
                    id_funcion: parseInt(id_funcion),
                    id_asiento: parseInt(cb.value),
                    precio: parseFloat(precio)
                }));

            if (asientosSeleccionados.length === 0) {
                return alert("Debes seleccionar al menos un asiento");
            }

            const data = {
                id_metodo: parseInt(id_metodo),
                entradas: asientosSeleccionados
            };

            try {
                const response = await fetch('/entradas/ingresar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok) {
                  alert("Venta realizada: ID " + result.result.id_venta);
                  window.location.reload(); // Recargar para limpiar
                } else {
                  alert("Error: " + result.message);
                }
            } catch (error) {
                console.error("Error en la petición:", error);
            }
        }
      </script>

    </main>
  </body>

  <%-include("../components/footer.ejs")%>