<%-include("../components/head.ejs")%>
  <body>

    <%-include("../components/nav.ejs")%>

    <main>
      <h1><%= title %></h1>

      <% if(salas_list.length <= 0) { %>
        <h2>No hay salas registradas</h1>
      <% }  %>

      <table>
          <thead>
              <tr>
                  <th>ID</th>
                  <th>Nombre</th>
                  <th>Capacidad</th>
                  <% if (user && user.rol === 'admin') { %>
                    <th>Administrar</th>
                  <% } %>
              </tr>
          </thead>
          <tbody>
              <% salas_list.forEach((s, i) => { %>
                  <tr>
                    <td><%= s.id_sala %></td>
                    <td><%= s.nombre %></td>
                    <td><%= s.capacidad %></td>
                    
                    <% if (user && user.rol === 'admin') { %>
                      <td>    
                        <div class="botonera">
                          <a class="botonera__opcion opcion__editar" href="/salas/actualizar/<%= s.id_sala %>" class="button">Editar</a>
                          <button class="botonera__opcion opcion__eliminar" onclick="eliminarSala(this, '<%= s.id_sala %>')"> X </button> 
                        </div>
                      </td>
                    <% } %>

                  </tr>
              <% }); %>
          </tbody>
      </table>

      <script>
        async function eliminarSala(boton, id) {
          if (!confirm('¿Estás seguro de eliminar esta sala?')) return;

          try {
            const response = await fetch(`/salas/eliminar/${id}`, {
              method: 'DELETE', 
              headers: {
                'Content-Type': 'application/json'
              }
            });

            if (response.ok) {
              const fila = boton.closest('tr'); //eliminar la fila de la tabla sin recargar
              fila.remove();
                  
              const tbody = document.querySelector('tbody');
              if (tbody.children.length === 0) {
                location.reload(); 
              }
            } else {
              alert('Error al eliminar la sala \n Posiblemente tenga relación con otra entidad');
            }
          } catch (error) {
            console.error('Error:', error);
            alert('Hubo un problema con la conexión');
          }
        }
      </script>

    </main>

  </body>

<%-include("../components/footer.ejs")%>