<%-include("../components/head.ejs")%>
<body>
    <%-include("../components/nav.ejs")%>
    <main>
      <h1><%= title %>: <%= peli.titulo %></h1>

      <form class="formEntidad" id="formEditarPelicula">
          <label>Título
              <input id="titulo_input" type="text" name="titulo" value="<%= peli.titulo %>">
          </label><br>

          <label>Año
              <input id="anio_input" type="number" name="anio" value="<%= peli.anio %>">
          </label><br>

          <label>Duración
              <input id="duracion_input" type="number" name="duracion" value="<%= peli.duracion %>">
          </label><br>

          <div>
            <label id="id_clasificacion">Clasificación</label><br>
              <% if(clasificaciones_list.length > 0) { %>
                <% clasificaciones_list.forEach((cl, i) => { %>

                  <label>
                    <%= cl.nombre %>
                    <input type="radio" value="<%= cl.id_clasificacion %>" name="id_clasificacion"
                    <%= cl.id_clasificacion == peli.id_clasificacion ? 'checked' : '' %>>
                  </label><br>

                <% }); %>
              <% } else { %>
                <p>No hay Clasificaciones para asignar</p>
              <% } %>
          </div>

          <div>
            <label id="categorias">Categorías</label><br>
              <% if(categorias_list.length > 0) { %>
                <% categorias_list.forEach((c, i) => { %>

                  <label>
                    <%= c.nombre %>
                    <input type="checkbox" value="<%= c.id_categoria %>" name="categorias"
                    <%= peli.categorias.some(peliCat => peliCat.id_categoria === c.id_categoria) ? 'checked' : '' %>>
                  </label><br>

                <% }); %>
              <% } else { %>
                <p>No hay Categorías para asignar</p>
              <% } %>
          </div>

        <button class="formEntidad__submit" type="button" onclick="actualizarPelicula('<%= peli.id_pelicula %>')">Guardar Cambios</button>

      </form>

      <script>
        async function actualizarPelicula(id) {
          const titulo = document.getElementById('titulo_input').value;
          const anio = document.getElementById('anio_input').value;
          const duracion = document.getElementById('duracion_input').value;

          const radioClasificacion = document.querySelector('input[name="id_clasificacion"]:checked');
          const id_clasificacion = radioClasificacion ? parseInt(radioClasificacion.value) : null;

          const checkboxesCategorias = document.querySelectorAll('input[name="categorias"]:checked');
          const categorias = Array.from(checkboxesCategorias).map(cb => parseInt(cb.value));

          const data = {
            titulo,
            anio,
            duracion,
            id_clasificacion,
            categorias
          };

          try {
            const response = await fetch(`/peliculas/editar/${id}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
              alert("Película actualizada con éxito");
              window.location.href = '/peliculas'; // Redirigir a la lista
            } else {
              // Si el servidor responde con 400 mostrar los mensajes de error
              const mensajesError = result.result.join("\n"); 
              alert("Error en la validación:\n" + mensajesError);
            }
          } catch (error) {
            console.error("Error:", error);
            alert("Ocurrió un problema al conectar con el servidor.");
          }
        }
      </script>

    </main>
</body>
<%-include("../components/footer.ejs")%>